;;       (sshr ty x (iconst_u kty (u64_and k (ty_shift_mask ty)))))
;; (rule (simplify (rotr ty x (iconst_u kty k)))
;;       (if-let $false (u64_eq k (u64_and k (ty_shift_mask ty))))
;;       (rotr ty x (iconst_u kty (u64_and k (ty_shift_mask ty)))))
