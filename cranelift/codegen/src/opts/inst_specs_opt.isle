;;       (ishl ty x (iconst_u kty (u64_and k (ty_shift_mask ty)))))
;; (rule (simplify (ushr ty x (iconst_u kty k)))
;;       (if-let $false (u64_eq k (u64_and k (ty_shift_mask ty))))
;;       (ushr ty x (iconst_u kty (u64_and k (ty_shift_mask ty)))))
