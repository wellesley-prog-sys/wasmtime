(spec (size_from_ty ty)
      (provide
            (= result (if (<= (:bits ty) 32) (OperandSize.Size32) (OperandSize.Size64))))
      (require
            (or
                  (= (:bits ty) 8)
                  (= (:bits ty) 16)
                  (= (:bits ty) 32)
                  (= (:bits ty) 64))))

