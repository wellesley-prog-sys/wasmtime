            (struct
                  (N (bv 1))
                  (Z (bv 1))
                  (C (bv 1))
                  (V (bv 1))
            )
      )
)

(macro (n_set nzcv) (= (:N nzcv) #b1))

(macro (n_clear nzcv) (= (:N nzcv) #b0))

(macro (z_set nzcv) (= (:Z nzcv) #b1))

(macro (z_clear nzcv) (= (:Z nzcv) #b0))

(macro (c_set nzcv) (= (:C nzcv) #b1))

(macro (c_clear nzcv) (= (:C nzcv) #b0))

(macro (v_set nzcv) (= (:V nzcv) #b1))

(macro (v_clear nzcv) (= (:V nzcv) #b0))

