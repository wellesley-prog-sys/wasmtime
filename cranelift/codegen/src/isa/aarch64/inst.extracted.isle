(spec (uimm12_scaled_from_i64 value ty)
      (match
            (let
                  (
                        (scale (bits2bytes! (int2bv 64 (:bits ty))))
                        (limit (bvmul (int2bv 64 4095) scale))
                  )
                  (and
                        (bvsge value (bvzero! 64))
                        (bvsle value limit)
                        (bv_is_zero! (bvand value (bvsub scale (bvone! 64))))
                  )
            )
      )
      (provide
            (= result (extract 11 0 (bvudiv value (bits2bytes! (int2bv 64 (:bits ty))))))
      )
)

(spec (simm9_from_i64 value)
      (provide (= value (sign_ext 64 result)))
      (match
            ; value >= -256
            (bvsge value (bvneg (int2bv 64 256)))
            ; value <= 255
            (bvsle value (int2bv 64 255))
      )
)

(attr sink_load_into_addr (veri chain))

(attr lower_constant_f16 (veri chain))

(spec (constant_f32 val)
      (provide (= result (sign_ext (widthof result) val))))
(spec (constant_f16 val)
      (provide (= result (sign_ext (widthof result) val))))

(attr constant_f64 (veri chain))

(spec (u64_low32_bits_unset n)
      (match (bv_is_zero! (bvand result #x00000000ffffffff)))
      (provide (= n result))
)

(spec (fp_cond_code cc)
      (provide
            (= result
                  (match cc
                        ((Equal) (Cond.Eq))
                        ((NotEqual) (Cond.Ne))
                        ((GreaterThanOrEqual) (Cond.Ge))
                        ((GreaterThan) (Cond.Gt))
                        ((LessThanOrEqual) (Cond.Ls))
                        ((LessThan) (Cond.Mi))
                  )
            )
      )
)

(spec (cond_code cc)
      (provide
            (= result
                  (match cc
                        ((Equal) (Cond.Eq))
                        ((NotEqual) (Cond.Ne))
                        ((SignedGreaterThanOrEqual) (Cond.Ge))
                        ((SignedGreaterThan) (Cond.Gt))
                        ((SignedLessThanOrEqual) (Cond.Le))
                        ((SignedLessThan) (Cond.Lt))
                        ((UnsignedGreaterThanOrEqual) (Cond.Hs))
                        ((UnsignedGreaterThan) (Cond.Hi))
                        ((UnsignedLessThanOrEqual) (Cond.Ls))
                        ((UnsignedLessThan) (Cond.Lo))
                  )
            )
      )
)

